# =========================================================================
# external-worker environment. Copy to .env and fill in. .env is git-ignored.
# =========================================================================

DEV_MODE=False
ENABLE_PERFORMANCE_LOGGER=True

# --- Shared PostgreSQL cluster ---
DB_USER=
DB_PASSWORD=
DB_HOST=your-postgres-host
DB_PORT=5432
# Two physical databases after the AIXII consolidation (aviation data + infra):
DB_AIXII_NAME=aixii
DB_SERVICE_NAME=service

# --- Shared Redis (ARQ broker — same instance as core-api) ---
REDIS_USER=
REDIS_USER_PASSWORD=
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# --- Scheduling (ARQ cron). Enable on EXACTLY ONE instance. ---
SCHEDULER_ENABLED=false

# --- Webhook URL building (kept in sync with core-api) ---
SELF_HOST=api.aixii.com
API_ROOT_URL=/api/v1
# REQUIRED — same value as core-api
MS_WEBHOOK_SECRET=

# --- Microsoft Graph ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GRAPHSCOPES=https://graph.microsoft.com/.default

# --- Airlabs ---
AIRLABS_API_KEY=

# --- FlightRadar ---
FLIGHT_RADAR_API_KEY=

# --- Aviation Edge ---
AVIATION_EDGE_API_KEY=
AVIATION_EDGE_EXTRA_API_KEY=
